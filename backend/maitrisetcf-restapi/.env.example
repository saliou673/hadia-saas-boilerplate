# ===========================
# 🛢 Database (PostgreSQL)
# ===========================
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE_NAME=maitrisetcf-db
POSTGRESQL_USERNAME=admin
POSTGRESQL_PASSWORD=admin

# =============================================================
# 🔐 JWT Configuration: The secret is used to cipher the tokens
# =============================================================
JWT_SECRET=your-jwt-secret-key
DEFAULT_TOKEN_VALIDITY_IN_SECONDS="1800" #30 minutes
TOKEN_VALIDITY_IN_SECONDS_FOR_REMEMBER_ME="2592000" #30 days

# =============================================================
# 💌 Mailing Configuration: Used to send email using SMTP
# =============================================================
# Option 1 (local dev): MailDev started from backend/docker/docker-compose.yml
# SMTP_HOST=localhost
# SMTP_PORT=1025
# MAIL_USERNAME=
# MAIL_PASSWORD=
# NO_REPLY_EMAIL=no-reply@maitrisetcf.local
#
# Option 2: Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# MAIL_USERNAME=your-gmail-address@gmail.com
# MAIL_PASSWORD=your-gmail-app-password
# NO_REPLY_EMAIL=your-gmail-address@gmail.com

WEB_APP_ORIGIN=http://localhost:4200

# =============================================================
# 👤 Account lifecycle durations
# =============================================================
# Each days at 1:00 AM
ACCOUNT_CLEANUP_CRON="0 0 1 * * ?"
NON_ACTIVATED_USER_RETENTION_PERIOD=3d
SOFT_DELETED_USER_RETENTION_PERIOD=30d
RESET_CODE_VALIDITY_PERIOD=5m
MANAGED_USER_INVITATION_CODE_LENGTH=8
MANAGED_USER_INVITATION_CODE_VALIDITY_PERIOD=1d
MANAGED_USER_INVITATION_ROUTE=account/invitation

# =============================================================
# 🚦 Rate limiting (Resilience4j)
# =============================================================
# Set RATE_LIMIT_ENABLED=false to disable rate limiting entirely (e.g. for local dev)
RATE_LIMIT_ENABLED=true
# Auth endpoints (login, register, activation, reset-password, recover, invitation)
RATE_LIMIT_AUTH_LIMIT=10
RATE_LIMIT_AUTH_REFRESH_PERIOD=1m
# All other API endpoints
RATE_LIMIT_API_LIMIT=100
RATE_LIMIT_API_REFRESH_PERIOD=1m

# =============================================================
# 📬 Contact form
# =============================================================
# Comma-separated list of email addresses that receive contact form submissions.
# Example with multiple recipients: support@maitrisetcf.local,admin@maitrisetcf.local
CONTACT_FORM_RECIPIENT_EMAILS=support@maitrisetcf.local

# =============================================================
# ⚙️ Other configurations
# =============================================================
CORS_ALLOWED_ORIGINS=host1,host2
